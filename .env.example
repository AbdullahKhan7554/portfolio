# ============================================================================
# Avenix Studio — Environment Variables (template)
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
#   cp .env.example .env.local
#
# RULES
#   • NEVER commit `.env.local` or real secrets (it is git-ignored).
#   • Variables prefixed NEXT_PUBLIC_* are exposed to the browser (safe, public).
#   • Variables WITHOUT that prefix are server-only secrets — keep them private.
#   • On Vercel, add the same keys under Project → Settings → Environment Variables.
#   • The site builds and runs with these placeholders; swap them at any time
#     without touching component code (everything reads from src/config/site.js).
# ============================================================================

# --- Public site identity -------------------------------------------------
# Canonical production URL (used for metadata, canonical tags, sitemap, OG).
NEXT_PUBLIC_SITE_URL="https://www.avenixstudios.com"

# --- Public contact channels ---------------------------------------------
# WhatsApp Business number in INTERNATIONAL format, digits only, no "+" or spaces.
NEXT_PUBLIC_WHATSAPP_NUMBER="923026234429"
# Public-facing email + phone shown on the site.
NEXT_PUBLIC_CONTACT_EMAIL="abdullahqayyum1041@gmail.com"
NEXT_PUBLIC_CONTACT_PHONE="+92 302 6234429"

# --- Analytics (public IDs, safe to expose) -------------------------------
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA4_ID=""
# Microsoft Clarity Project ID. Leave blank to disable.
NEXT_PUBLIC_CLARITY_ID=""

# --- Email delivery (SERVER-ONLY SECRETS — never expose) ------------------
# Resend API key for the contact + lead-magnet forms. Get one at resend.com.
RESEND_API_KEY=""
# Verified sender. Use "onboarding@resend.dev" until your domain is verified.
CONTACT_FROM_EMAIL="Avenix Studio <onboarding@resend.dev>"
# Inbox that receives lead notifications.
CONTACT_TO_EMAIL="abdullahqayyum1041@gmail.com"

# --- Nova AI provider (SERVER-ONLY SECRETS — never expose) ----------------
# Nova is provider-agnostic. Supported providers: Google AI Studio (Gemini) and
# NVIDIA NIM. Set NOVA_PROVIDER to pick the active one; if its key is missing,
# Nova falls back to any other supported provider that HAS a key. Leave all keys
# blank to disable Nova (the widget shows a graceful fallback message).
NOVA_PROVIDER="gemini"

# Google AI Studio (Gemini). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional overrides:
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

# NVIDIA NIM. Get a key at https://build.nvidia.com
NVIDIA_API_KEY=""
# Optional overrides:
NVIDIA_MODEL="meta/llama-3.1-8b-instruct"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
